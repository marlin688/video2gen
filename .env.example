# ============================================================
# video2gen 配置
# ============================================================

# --- 路径配置 ---
TRENDING_CSV_PATH=../youtube-trending/data/latest.csv
L2N_OUTPUT_DIR=../lecture2note/output/subtitle
# SOURCES_DIR=sources

# --- TTS 配置 ---
TTS_VOICE=zh-CN-YunxiNeural
TTS_RATE=+5%

# --- 脚本生成模型 ---
SCRIPT_MODEL=gpt-5.4

# --- 视频输出参数 ---
VIDEO_RESOLUTION=1920x1080
VIDEO_CRF=20

# --- API 平台切换 (复用 lecture2note 格式) ---
# API_PLATFORM=itssx

# --- Anthropic (直连或中转) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=

# --- Gemini (图片生成用) ---
# GEMINI_API_KEY=
# GEMINI_BASE_URL=
# GEMINI_IMAGE_API_KEY=
# GEMINI_IMAGE_BASE_URL=
# GEMINI_IMAGE_MODEL=

# --- OpenAI 兼容接口 (GPT/DeepSeek/Qwen 等，通过代理) ---
# GPT_API_KEY=
# GPT_BASE_URL=https://api.openai.com
# OPENAI_AUTH_FILE=/absolute/path/to/auth.json
# CODEX_AUTH_FILE=/absolute/path/to/auth.json
# OPENAI_PROXY=http://127.0.0.1:7890
# OPENAI_CODEX_BASE_URL=https://chatgpt.com/backend-api/codex

# --- 智谱 GLM (官方 API) ---
# ZHIPU_API_KEY=

# --- MiniMax (官方 API，与 TTS 共用 Key) ---
# TTS_MINMAX_KEY=

# --- TTS 引擎: voxcpm (本地高质量默认) / edge / minimax / sovits ---
# TTS_ENGINE=voxcpm
# --- VoxCPM (https://github.com/OpenBMB/VoxCPM) ---
# TTS_VOXCPM_MODEL=openbmb/VoxCPM2
# TTS_VOXCPM_DEVICE=auto
# TTS_VOXCPM_OPTIMIZE=true
# TTS_VOXCPM_LOAD_DENOISER=false
# TTS_VOXCPM_CFG_VALUE=2.0
# TTS_VOXCPM_INFERENCE_TIMESTEPS=10
# TTS_VOXCPM_NORMALIZE=false
# TTS_VOXCPM_DENOISE=false
# TTS_VOXCPM_RETRY_BADCASE=true
# TTS_VOXCPM_CONTROL=Calm and natural style
# TTS_VOXCPM_REFERENCE_AUDIO=/path/to/reference.wav
# TTS_VOXCPM_PROMPT_AUDIO=/path/to/prompt.wav
# TTS_VOXCPM_PROMPT_TEXT=参考音频对应文本
# TTS_MINIMAX_VOICE_ID=
# --- GPT-SoVITS 声音克隆 (需先部署 API 服务器) ---
# TTS_SOVITS_URL=http://127.0.0.1:9880
# TTS_SOVITS_REF_AUDIO=/path/to/your_voice_sample.wav
# TTS_SOVITS_REF_TEXT=这是参考音频对应的文字内容

# --- Remotion 渲染 ---
# V2G_THEME=tech-blue
# REMOTION_CHROME_EXECUTABLE=/path/to/chrome

# --- 成本控制 ---
# V2G_MAX_TOKENS=500000

# --- 中转平台示例 ---
# ITSSX_API_KEY=
# ITSSX_BASE_URL=https://crs.itssx.com/api
# ITSSX_MODEL=

# ============================================================
# Scout 自动化 (v2g scout)
# ============================================================

# --- Obsidian vault 路径 (不设置则输出到 output/scout/) ---
# OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# --- 知识源分析模型 ---
# SCOUT_MODEL=claude-sonnet-4-5-20250929

# --- GitHub 趋势监控 (无需 API Key) ---
# GITHUB_TOPICS=ai,ml,llm,agent,rag

# --- Hacker News 监控 ---
# HN_KEYWORDS=AI,LLM,Claude,GPT,agent,RAG

# --- Twitter/X 监控 (TwitterAPI.io, $0.15/1000条) ---
# TWITTER_API_IO_KEY=
# --- Apify (其他 Actor 用) ---
# APIFY_TOKEN=
# TWITTER_KEYWORDS=claude,cursor,ai agent,mcp,llm
# TWITTER_AUTHORS=AnthropicAI,OpenAI,kaborosu

# --- 文章监控 (RSS URL，逗号分隔，可选) ---
# ARTICLE_RSS_URLS=

# --- SQLite 去重数据库路径 ---
# SCOUT_DB_PATH=data/scout.db

# --- YouTube Data API v3 (创意构思/竞品分析用，可选) ---
# YOUTUBE_API_KEY=AIzaSy...

# --- Telegram 通知 (可选) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ============================================================
# B站数据采集 (v2g assets fetch)
# ============================================================

# --- B站 Cookie (从浏览器 DevTools 获取，用于创作中心 API) ---
# BILIBILI_SESSDATA=
# BILIBILI_BILI_JCT=
# --- 自定义留存曲线 API endpoint (如果默认路径失效) ---
# BILIBILI_RETENTION_API=

# ============================================================
# 自动配图 (v2g image)
# ============================================================

# --- Bing Image Search (免费 1000 次/月) ---
# BING_IMAGE_API_KEY=

# --- AI 生图 (DALL-E 3 via GPT proxy，或 Gemini Imagen) ---
# 优先使用 GPT_API_KEY (上方已配置) 调用 DALL-E 3
# 备选: GEMINI_IMAGE_API_KEY (上方已配置)
